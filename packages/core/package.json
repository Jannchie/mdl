{
  "name": "@jannchie/mdl-core",
  "type": "module",
  "version": "0.2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./src/internal.ts",
      "default": "./dist/internal.js"
    },
    "./dev": {
      "types": "./src/dev.ts",
      "default": "./src/dev.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  }
}
