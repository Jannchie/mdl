{
  "name": "@jannchie/mdl-cli",
  "type": "module",
  "version": "0.3.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dev": {
      "types": "./src/dev.ts",
      "default": "./src/dev.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mdl": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/dev.ts",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@jannchie/mdl-core": "workspace:*",
    "@jannchie/mdl-sdk": "workspace:*",
    "cac": "^6.7.14",
    "cli-table3": "^0.6.5"
  }
}
